{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": [
      "node",
      "vscode"
    ],
    "strict": true,
    "declaration": true,
    "isolatedDeclarations": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
    "outDir": "./extension/dist",
    "rootDir": "./extension/src"
  },
  "include": [
    "extension/src/**/*"
  ]
}
