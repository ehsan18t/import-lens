{
  "name": "import-lens",
  "displayName": "ImportLens",
  "description": "VS Code import size analyzer backed by a native Rust daemon.",
  "version": "0.1.0",
  "publisher": "importlens",
  "license": "MIT",
  "icon": "media/icon.png",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "main": "./extension/dist/extension.cjs",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:svelte",
    "onLanguage:astro"
  ],
  "contributes": {
    "commands": [
      {
        "command": "importLens.clearCache",
        "title": "ImportLens: Clear Cache",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showLogs",
        "title": "ImportLens: Show Logs",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showReport",
        "title": "ImportLens: Show Report",
        "category": "ImportLens"
      },
      {
        "command": "importLens.copyImportDiagnostics",
        "title": "ImportLens: Copy Import Diagnostics",
        "category": "ImportLens"
      }
    ],
    "configuration": {
      "title": "ImportLens",
      "properties": {
        "importLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Toggle ImportLens on or off."
        },
        "importLens.display": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "verbose",
            "inlayHint"
          ],
          "default": "inlayHint",
          "description": "Display format for import size annotations."
        },
        "importLens.compression": {
          "type": "string",
          "enum": [
            "brotli",
            "gzip",
            "zstd",
            "all"
          ],
          "default": "brotli",
          "description": "Primary compression format shown in minimal and standard displays."
        },
        "importLens.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Milliseconds to wait after the last document change before analyzing imports."
        },
        "importLens.showWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warning indicators for imports that may not tree-shake accurately."
        },
        "importLens.useCodeLens": {
          "type": "boolean",
          "default": false,
          "description": "Use CodeLens instead of end-of-line decorations. Ignored when display is inlayHint."
        },
        "importLens.enableDiskCache": {
          "type": "boolean",
          "default": true,
          "description": "Persist computed sizes to disk across editor restarts."
        },
        "importLens.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "error",
          "description": "Logging verbosity for the ImportLens output channel."
        }
      }
    }
  },
  "files": [
    "extension/dist/extension.cjs",
    "bin/",
    "media/icon.png",
    "node_modules/oxc-parser/",
    "node_modules/@oxc-project/types/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm test:ts && pnpm test:scripts && pnpm test:rust",
    "test:ts": "tsc -p tsconfig.test.json && node --test \"extension/test-dist/**/*.test.js\"",
    "test:scripts": "node --test \"scripts/**/*.test.mjs\"",
    "test:rust": "cargo test --workspace",
    "test:performance": "cargo test -p import-lens-daemon --test performance -- --nocapture",
    "coverage:rust": "node scripts/check-coverage.mjs",
    "build:daemon": "node scripts/build-daemon.mjs",
    "build:daemon:win32-x64": "node scripts/build-daemon.mjs win32-x64",
    "build:daemon:win32-arm64": "node scripts/build-daemon.mjs win32-arm64",
    "build:daemon:linux-x64": "node scripts/build-daemon.mjs linux-x64",
    "build:daemon:linux-arm64": "node scripts/build-daemon.mjs linux-arm64",
    "build:daemon:darwin-x64": "node scripts/build-daemon.mjs darwin-x64",
    "build:daemon:darwin-arm64": "node scripts/build-daemon.mjs darwin-arm64",
    "copy:daemon:win32-x64": "node scripts/copy-daemon.mjs win32-x64",
    "copy:daemon:win32-arm64": "node scripts/copy-daemon.mjs win32-arm64",
    "copy:daemon:linux-x64": "node scripts/copy-daemon.mjs linux-x64",
    "copy:daemon:linux-arm64": "node scripts/copy-daemon.mjs linux-arm64",
    "copy:daemon:darwin-x64": "node scripts/copy-daemon.mjs darwin-x64",
    "copy:daemon:darwin-arm64": "node scripts/copy-daemon.mjs darwin-arm64",
    "hash:daemon": "node scripts/generate-daemon-hashes.mjs",
    "assert:vsix-size": "node scripts/assert-vsix-size.mjs",
    "package:win32-x64": "node scripts/package-target.mjs win32-x64",
    "package:win32-arm64": "node scripts/package-target.mjs win32-arm64",
    "package:linux-x64": "node scripts/package-target.mjs linux-x64",
    "package:linux-arm64": "node scripts/package-target.mjs linux-arm64",
    "package:darwin-x64": "node scripts/package-target.mjs darwin-x64",
    "package:darwin-arm64": "node scripts/package-target.mjs darwin-arm64",
    "package:linux-x64:zig": "node scripts/package-target.mjs linux-x64 --zigbuild",
    "package:linux-arm64:zig": "node scripts/package-target.mjs linux-arm64 --zigbuild",
    "package:darwin-x64:zig": "node scripts/package-target.mjs darwin-x64 --zigbuild",
    "package:darwin-arm64:zig": "node scripts/package-target.mjs darwin-arm64 --zigbuild",
    "package:all:native": "pnpm package:win32-x64 && pnpm package:win32-arm64 && pnpm package:linux-x64 && pnpm package:linux-arm64 && pnpm package:darwin-x64 && pnpm package:darwin-arm64",
    "package:all:zig": "pnpm package:linux-x64:zig && pnpm package:linux-arm64:zig && pnpm package:darwin-x64:zig && pnpm package:darwin-arm64:zig",
    "docker:build": "node scripts/docker-build.mjs"
  },
  "dependencies": {
    "@msgpack/msgpack": "3.1.3",
    "oxc-parser": "0.133.0"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/vscode": "1.100.0",
    "@vscode/vsce": "3.9.1",
    "tsdown": "0.22.1",
    "typescript": "6.0.3"
  }
}
