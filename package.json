{
  "name": "import-lens",
  "displayName": "ImportLens",
  "description": "VS Code import size analyzer backed by a native Rust daemon.",
  "version": "0.1.0",
  "publisher": "importlens",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehsan18t/import-lens.git"
  },
  "icon": "media/icon.png",
  "private": true,
  "type": "module",
  "bin": {
    "importlens": "./cli/importlens.mjs"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "main": "./dist/extension/extension.cjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:vue"
  ],
  "contributes": {
    "commands": [
      {
        "command": "importLens.clearCache",
        "title": "ImportLens: Clear Current Project Cache",
        "category": "ImportLens"
      },
      {
        "command": "importLens.clearAllCaches",
        "title": "ImportLens: Clear All Caches",
        "category": "ImportLens"
      },
      {
        "command": "importLens.manageCache",
        "title": "ImportLens: Manage Cache",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showLogs",
        "title": "ImportLens: Show Logs",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showCurrentFileSize",
        "title": "ImportLens: Show Current File Size",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showBundleImpactHistory",
        "title": "ImportLens: Show Bundle Impact History",
        "category": "ImportLens"
      },
      {
        "command": "importLens.showReport",
        "title": "ImportLens: Show Report",
        "category": "ImportLens"
      },
      {
        "command": "importLens.compareImports",
        "title": "ImportLens: Compare Imports",
        "category": "ImportLens"
      },
      {
        "command": "importLens.copyImportDiagnostics",
        "title": "ImportLens: Copy Import Diagnostics",
        "category": "ImportLens"
      }
    ],
    "configuration": {
      "title": "ImportLens",
      "properties": {
        "importLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Toggle ImportLens on or off."
        },
        "importLens.display": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "verbose",
            "inlayHint"
          ],
          "default": "inlayHint",
          "description": "Display format for import size annotations."
        },
        "importLens.inlineRenderer": {
          "type": "string",
          "enum": [
            "native",
            "colored"
          ],
          "default": "colored",
          "description": "Renderer used when importLens.display is inlayHint. Colored uses decoration-backed inline text with confidence colors; native uses VS Code's accessible Inlay Hints API."
        },
        "importLens.compression": {
          "type": "string",
          "enum": [
            "brotli",
            "gzip",
            "zstd",
            "all"
          ],
          "default": "brotli",
          "description": "Primary compression format shown in minimal and standard displays."
        },
        "importLens.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Milliseconds to wait after the last document change before analyzing imports."
        },
        "importLens.showWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warning indicators for imports that may not tree-shake accurately."
        },
        "importLens.budgets": {
          "type": "object",
          "default": {},
          "description": "Bundle budget thresholds in bytes. ImportLens currently supports perImportBrotliBytes and perFileBrotliBytes.",
          "properties": {
            "perImportBrotliBytes": {
              "type": "number",
              "minimum": 1,
              "description": "Warn when a single import's Brotli size exceeds this many bytes."
            },
            "perFileBrotliBytes": {
              "type": "number",
              "minimum": 1,
              "description": "Warn when analyzed imports in a file exceed this total Brotli budget."
            }
          },
          "additionalProperties": false
        },
        "importLens.useCodeLens": {
          "type": "boolean",
          "default": false,
          "description": "Use CodeLens instead of end-of-line decorations. Ignored when display is inlayHint."
        },
        "importLens.enableDiskCache": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Persist computed sizes to disk across editor restarts. Use the `ImportLens: Manage Cache` command to inspect or clean cached data."
        },
        "importLens.cacheMaxSizeMB": {
          "type": "number",
          "default": 512,
          "minimum": 64,
          "description": "Maximum disk space in megabytes used by ImportLens project caches before least-recently-used cleanup runs."
        },
        "importLens.cacheMaxAgeDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Maximum age in days for inactive ImportLens project caches before automatic cleanup removes them."
        },
        "importLens.enableRegistryHints": {
          "type": "boolean",
          "default": true,
          "description": "Enable short-timeout npm registry metadata hints for package.json dependency surfaces."
        },
        "importLens.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Logging verbosity for the ImportLens output channel."
        }
      }
    }
  },
  "files": [
    "dist/extension/extension.cjs",
    "dist/bin/",
    "cli/",
    "media/icon.png",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "prepare": "lefthook install && git config commit.template .gitmessage",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "pnpm build && pnpm test:ts && pnpm test:scripts && pnpm test:rust",
    "test:ts": "node -e \"require('node:fs').rmSync('dist/test-dist', { recursive: true, force: true })\" && tsc -p tsconfig.test.json && node --test \"dist/test-dist/**/*.test.js\"",
    "test:scripts": "node --test \"scripts/**/*.test.mjs\"",
    "test:rust": "cargo test --workspace",
    "test:accuracy": "node scripts/accuracy-compare.mjs",
    "test:performance": "cargo test -p import-lens-daemon --release --test performance -- --ignored --nocapture",
    "coverage:rust": "node scripts/check-coverage.mjs",
    "build:daemon": "node scripts/build-daemon.mjs",
    "build:daemon:win32-x64": "node scripts/build-daemon.mjs win32-x64",
    "build:daemon:win32-arm64": "node scripts/build-daemon.mjs win32-arm64",
    "build:daemon:linux-x64": "node scripts/build-daemon.mjs linux-x64",
    "build:daemon:linux-arm64": "node scripts/build-daemon.mjs linux-arm64",
    "build:daemon:darwin-x64": "node scripts/build-daemon.mjs darwin-x64",
    "build:daemon:darwin-arm64": "node scripts/build-daemon.mjs darwin-arm64",
    "copy:daemon:win32-x64": "node scripts/copy-daemon.mjs win32-x64",
    "copy:daemon:win32-arm64": "node scripts/copy-daemon.mjs win32-arm64",
    "copy:daemon:linux-x64": "node scripts/copy-daemon.mjs linux-x64",
    "copy:daemon:linux-arm64": "node scripts/copy-daemon.mjs linux-arm64",
    "copy:daemon:darwin-x64": "node scripts/copy-daemon.mjs darwin-x64",
    "copy:daemon:darwin-arm64": "node scripts/copy-daemon.mjs darwin-arm64",
    "hash:daemon": "node scripts/generate-daemon-hashes.mjs",
    "assert:vsix-size": "node scripts/assert-vsix-size.mjs",
    "package:win32-x64": "node scripts/package-target.mjs win32-x64",
    "package:win32-arm64": "node scripts/package-target.mjs win32-arm64",
    "package:linux-x64": "node scripts/package-target.mjs linux-x64",
    "package:linux-arm64": "node scripts/package-target.mjs linux-arm64",
    "package:darwin-x64": "node scripts/package-target.mjs darwin-x64",
    "package:darwin-arm64": "node scripts/package-target.mjs darwin-arm64",
    "package:linux-x64:zig": "node scripts/package-target.mjs linux-x64 --zigbuild",
    "package:linux-arm64:zig": "node scripts/package-target.mjs linux-arm64 --zigbuild",
    "package:darwin-x64:zig": "node scripts/package-target.mjs darwin-x64 --zigbuild",
    "package:darwin-arm64:zig": "node scripts/package-target.mjs darwin-arm64 --zigbuild",
    "package:win32-x64:xwin": "node scripts/package-target.mjs win32-x64 --xwin",
    "package:win32-arm64:xwin": "node scripts/package-target.mjs win32-arm64 --xwin",
    "package:all:native": "pnpm package:win32-x64 && pnpm package:win32-arm64 && pnpm package:linux-x64 && pnpm package:linux-arm64 && pnpm package:darwin-x64 && pnpm package:darwin-arm64",
    "package:all:zig": "pnpm package:linux-x64:zig && pnpm package:linux-arm64:zig && pnpm package:darwin-x64:zig && pnpm package:darwin-arm64:zig",
    "docker:build": "docker compose run --rm --build builder",
    "changelog": "node scripts/generate-changelog.mjs",
    "deps:update:oxc": "node scripts/update-oxc-stack.mjs",
    "deps:update:safe": "pnpm update && cargo update"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^24.13.2",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "lefthook": "^2.1.9",
    "ovsx": "^1.0.2",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3"
  }
}
